{
  "name": "boston-mcp-hack",
  "displayName": "Boston 311 Hackathon Starter",
  "description": "Hackathon starter for building AI agents on City of Boston 311 data — powered by Subconscious",
  "version": "1.0.0",
  "private": true,
  "subconscious": {
    "language": "typescript",
    "framework": "Next.js",
    "tags": [
      "typescript",
      "web",
      "local",
      "boston-311",
      "hackathon",
      "mcp"
    ],
    "envVars": {
      "SUBCONSCIOUS_API_KEY": {
        "required": true
      }
    }
  },
  "setup": [
    "npm install",
    "cp .env.example .env.local",
    "echo \"SUBCONSCIOUS_API_KEY=your_key\" >> .env.local",
    "npm run dev"
  ],
  "scripts": {
    "dev": "node scripts/dev-tunnel.mjs",
    "dev:no-tunnel": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "subconscious": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
